{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":enablePreCommit"],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackageNames": ["node"],
      "allowedVersions": "/24\\.[0-9]+\\.[0-9]+$/"
    }
  ]
}
